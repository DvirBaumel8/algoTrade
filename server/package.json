{
  "name": "algotrade-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "db:generate": "drizzle-kit generate:pg --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit push:pg --config=drizzle.config.ts",
    "sync:stocks": "ts-node -r dotenv/config src/scripts/sync-stocks.ts"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "yahoo-finance2": "^2.13.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.5",
    "drizzle-kit": "^0.20.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
